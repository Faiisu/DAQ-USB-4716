FROM python:3.11-slim

WORKDIR /app

# Install dependencies (psycopg2-binary is needed for database connection)
RUN pip install --no-cache-dir psycopg2-binary

# Copy the agent script into the container
COPY pipeline_agent.py /app/pipeline_agent.py

# Make the script executable
RUN chmod +x /app/pipeline_agent.py

# Run the agent script
ENTRYPOINT ["python", "/app/pipeline_agent.py"]
